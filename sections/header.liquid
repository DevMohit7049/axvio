<nav class="header-nav">
  <div class="left-nav">
    <a href="/">
      <img
        width="15"
        height="18"
        loading="lazy"
        src="{{ 'logo.svg' | asset_url }}"
      >
    </a>
  </div>

  <div class="middle-nav">
    <ul class="middle-nav-links">
       {% for link in linklists['main-menu'].links %}
        <li>{{ link.title | link_to: 'link.url' }}</li>
       {% endfor %}
    </ul>
  </div>


    <div class="right-nav">
    <a href="/cart">
      <img
        width="20"
        height="23"
        loading="lazy"
        src="{{ 'cart.png' | asset_url }}"
      >
    </a>
    <p>{{ cart.item_count }}</p>
  </div>

</nav>


<style>
  .header-nav{
    display:flex;
    justify-content:center;
    margin:0;
    padding:1px;
    background-color:color;
    padding:0 30px 0 30px;
  }

  .left-nav{
    display:flex;
    align-items:center;
    position:relative;
  }

  .middle-nav-links{
    display:flex;
    font-size:16px;
  }
  
  .middle-nav-links li{
    list-style-type:none;
    padding-left:10px;
    padding-right:10px
  }

  .middle-nav-links li:hover{
    text-decoration:underline;
  }

  .middle-nav-links a{
    text-decoration:none;
    color:inherit;
  }

  @media (max-width:480px){
    .header-nav{
      padding-top:10px;
    }

    .middle-nav{
      display:none;
    }
  }

</style>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
