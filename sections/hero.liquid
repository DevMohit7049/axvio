<section>
  <div>
    {% if section.settings.image != blank %}
      <div class="with-image">
        <div class="content-container">
          <h1>{{ section.settings.title_text }}</h1>
          <p>{{ section.settings.description_text }}</p>

          {% if section.blocks.size == 0 %}
            <div class="buttons">
              <a href="#" class="button">Learn More</a>
              <a href="#" class="button">Buy Now</a>
            </div>
          {% else %}
            <div class="buttons_dynamic">
              <a href="{{ block.settings.button_url }}" class="button">{{ block.settings.button_text | escape }}</a>
            </div>
          {% endif %}
        </div>
      </div>
    {% else %}
    
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "hero",
  "settings": [
    {
      "type": "text",
      "id": "title_text",
      "label": "Title Text",
      "default": "hello"
    },

    {
      "type": "text",
      "id": "description_text",
      "label": "Description",
      "default": "this is description text"
    },

    {
     "type": "image_picker",
     "id": "image",
     "label": "image",
     "info": "400 X 120px "
    
    }

  ],
  "presets": [
    {
      "name": "hero"
    }
  ]
}
{% endschema %}
